<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE configuration
  PUBLIC "-//mybatis.org//DTD Config 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-config.dtd">
  
    <configuration>
  	<settings>
  		<!-- mapUnderscoreToCamelCase => 필수로 사용함 -->
<!--  		<setting name="mapUnderscoreToCamelCase" value="true"/>		&lt;!&ndash; DB 컬럼명에 _ (Underscore)가 포함되어 있을 때 이를 자동으로 카멜 표기법의 DTO와 매핑해준다. 만약 이 설정이 없으면 _ (Undersocre)가 포함된 컬럼의 값은 null로 리턴된다. &ndash;&gt;-->
  		<setting name="jdbcTypeForNull" value="NULL"/>				<!-- 옵셔널임.  SQL문에 Null 이 들어갔을 떄 어떻게 처리할 건지.. (일단 우리는 NULL 로 처리하기로 함) -->
  	</settings>
  	
	<typeAliases>
		<!-- VO 클래스에 대해 별칭 설정 => 필수로 사용함 -->
		<package name="com.proj.travelog"/>		<!-- VO 클래스를 쓸 때 별칭을 주는 것..? (패키지 내 모든 VO인 듯!)  -->
	</typeAliases>
	
	<typeHandlers>
		<typeHandler javaType="java.sql.Date" handler="org.apache.ibatis.type.DateTypeHandler"/>    	<!-- (풀네임 작성해야 함) 여러가지 타입에 대해 어떤 식으로 처리할건지 설정..? -->
	</typeHandlers>
  </configuration>